#!/usr/bin/env bash
set -euo pipefail

POLYBAR_DIR="${HOME}/.config/polybar"
CURRENT_THEME_FILE="${POLYBAR_DIR}/.current_theme"
CURRENT_PANEL_FILE="${POLYBAR_DIR}/.current_panel_variant"

fallback() {
  i3-nagbar -t warning \
    -m "You pressed the exit shortcut. Do you really want to exit i3? This will end your X session." \
    -b "Yes, exit i3" "i3-msg exit"
}

if [[ ! -d "$POLYBAR_DIR" ]]; then
  fallback
fi

theme=""
if [[ -f "$CURRENT_THEME_FILE" ]]; then
  theme="$(tr -d '[:space:]' < "$CURRENT_THEME_FILE")"
fi

if [[ -z "$theme" ]]; then
  for candidate in cuts hack material shades shapes blocks docky forest grayblocks colorblocks pwidgets panels; do
    if [[ -d "${POLYBAR_DIR}/${candidate}" ]]; then
      theme="$candidate"
      break
    fi
  done
fi

if [[ -z "$theme" ]]; then
  fallback
fi

if [[ "$theme" == "panels" ]]; then
  panel_variant="--gnome"
  if [[ -f "$CURRENT_PANEL_FILE" ]]; then
    raw_variant="$(tr -d '[:space:]' < "$CURRENT_PANEL_FILE")"
    if [[ -n "$raw_variant" ]]; then
      case "$raw_variant" in
        --budgie|--deepin|--elight|--edark|--gnome|--klight|--kdark|--liri|--mint|--ugnome|--unity|--xubuntu|--zorin)
          panel_variant="$raw_variant"
          ;;
      esac
    fi
  fi

  powermenu="${POLYBAR_DIR}/panels/scripts/powermenu.sh"
  if [[ -x "$powermenu" ]]; then
    exec "$powermenu" "$panel_variant"
  elif [[ -f "$powermenu" ]]; then
    exec bash "$powermenu" "$panel_variant"
  else
    fallback
  fi
fi

powermenu="${POLYBAR_DIR}/${theme}/scripts/powermenu.sh"
if [[ -x "$powermenu" ]]; then
  exec "$powermenu"
elif [[ -f "$powermenu" ]]; then
  exec bash "$powermenu"
else
  fallback
fi
