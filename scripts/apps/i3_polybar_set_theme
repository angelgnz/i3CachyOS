#!/usr/bin/env bash
set -euo pipefail

POLYBAR_DIR="${HOME}/.config/polybar"
LAUNCH_SCRIPT="${POLYBAR_DIR}/launch.sh"
CURRENT_THEME_FILE="${POLYBAR_DIR}/.current_theme"
CURRENT_PANEL_FILE="${POLYBAR_DIR}/.current_panel_variant"
WALLPAPER_DIR_DEFAULT="${HOME}/Images/wallpapers"
WALLPAPER_DIR_ALT="${HOME}/Imágenes/wallpapers"

usage() {
  cat <<'EOF'
Uso:
  i3_polybar_set_theme <tema> [panel_variant]

Ejemplos:
  i3_polybar_set_theme cuts
  i3_polybar_set_theme hack
  i3_polybar_set_theme panels --gnome

Temas soportados:
  blocks colorblocks cuts docky forest grayblocks hack material
  panels pwidgets shades shapes

Panel variants validos para 'panels':
  --budgie --deepin --elight --edark --gnome --klight --kdark
  --liri --mint --ugnome --unity --xubuntu --zorin
EOF
}

is_valid_theme() {
  case "$1" in
    blocks|colorblocks|cuts|docky|forest|grayblocks|hack|material|panels|pwidgets|shades|shapes)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_valid_panel_variant() {
  case "$1" in
    --budgie|--deepin|--elight|--edark|--gnome|--klight|--kdark|--liri|--mint|--ugnome|--unity|--xubuntu|--zorin)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" || $# -eq 0 ]]; then
  usage
  exit 0
fi

if [[ ! -d "$POLYBAR_DIR" ]]; then
  echo "[ERROR] No existe: $POLYBAR_DIR" >&2
  echo "Instala primero polybar-themes (setup.sh)." >&2
  exit 1
fi

if [[ ! -f "$LAUNCH_SCRIPT" ]]; then
  echo "[ERROR] No existe launch script: $LAUNCH_SCRIPT" >&2
  echo "Revisa tu instalacion de polybar-themes." >&2
  exit 1
fi

theme="$1"
shift || true

if ! is_valid_theme "$theme"; then
  echo "[ERROR] Tema no valido: $theme" >&2
  usage
  exit 1
fi

panel_variant=""
if [[ "$theme" == "panels" ]]; then
  panel_variant="${1:---gnome}"
  if ! is_valid_panel_variant "$panel_variant"; then
    echo "[ERROR] Panel variant no valido: $panel_variant" >&2
    usage
    exit 1
  fi
fi

printf '%s\n' "$theme" > "$CURRENT_THEME_FILE"

if [[ "$theme" == "panels" ]]; then
  printf '%s\n' "$panel_variant" > "$CURRENT_PANEL_FILE"
else
  rm -f "$CURRENT_PANEL_FILE"
fi

echo "[INFO] Tema activo: $theme"
if [[ "$theme" == "panels" ]]; then
  echo "[INFO] Panel variant activo: $panel_variant"
fi

pywal_input="$WALLPAPER_DIR_DEFAULT"
if [[ ! -d "$pywal_input" && -d "$WALLPAPER_DIR_ALT" ]]; then
  pywal_input="$WALLPAPER_DIR_ALT"
fi

pywal_script="${POLYBAR_DIR}/${theme}/scripts/pywal.sh"
if [[ -f "$pywal_script" ]]; then
  if command -v wal >/dev/null 2>&1; then
    if [[ -d "$pywal_input" || -f "$pywal_input" ]]; then
      echo "[INFO] Aplicando pywal con: $pywal_input"
      if ! bash "$pywal_script" "$pywal_input"; then
        echo "[WARN] Fallo pywal.sh para el tema '$theme'. Continuando con launch.sh." >&2
      fi
    else
      echo "[WARN] No existe ruta de wallpapers para pywal: $pywal_input" >&2
      echo "[WARN] Se omite pywal y se continua con launch.sh." >&2
    fi
  else
    echo "[WARN] No se encontro el comando 'wal' (pywal). Se omite pywal." >&2
  fi
else
  echo "[WARN] El tema '$theme' no tiene scripts/pywal.sh. Se omite pywal." >&2
fi

exec bash "$LAUNCH_SCRIPT" "--$theme"
